{
  "permissions": {
    "allow": [
      "Bash(dotnet test:*)",
      "Bash(dotnet build:*)",
      "Read(//usr/bin/**)",
      "WebSearch",
      "WebFetch(domain:www.nuget.org)",
      "WebFetch(domain:github.com)",
      "Bash(dotnet restore:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sS --connect-timeout 2 http://host.docker.internal:60971/hook/stop?ptyId=ddd1d0e6-194d-4900-8c15-3df46ddc9f41"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sS --connect-timeout 2 http://host.docker.internal:60971/hook/busy?ptyId=ddd1d0e6-194d-4900-8c15-3df46ddc9f41"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "curl -sS --connect-timeout 2 -X POST -H \"Content-Type: application/json\" -d @- http://host.docker.internal:60971/hook/notification?ptyId=ddd1d0e6-194d-4900-8c15-3df46ddc9f41"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "curl -sS --connect-timeout 2 -X POST -H \"Content-Type: application/json\" -d @- http://host.docker.internal:60971/hook/notification?ptyId=ddd1d0e6-194d-4900-8c15-3df46ddc9f41"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Tool WebSearch is disabled — web traffic is routed through api.anthropic.com and bypasses the container firewall\" >&2; exit 2"
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "\n\nCo-Authored-By: Claude <noreply@anthropic.com> via Conducktor <conducktor@contextand.com>"
  }
}
